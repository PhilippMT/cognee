# Environment variables template for Cognee Web Scraper

# vLLM Server Configuration (for local ReaderLM-v2)
VLLM_API_BASE=http://localhost:8000/v1
VLLM_MODEL_NAME=jinaai/ReaderLM-v2
VLLM_API_KEY=token-abc123

# LLM Provider for Cognee (choose one)
LLM_PROVIDER=openai
LLM_MODEL=gpt-4
LLM_API_KEY=your_openai_api_key_here
LLM_ENDPOINT=
LLM_API_VERSION=

# Embedding Provider for Cognee
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_API_KEY=your_openai_api_key_here
EMBEDDING_ENDPOINT=
EMBEDDING_API_VERSION=

# Alternative: Use local Ollama
# LLM_PROVIDER=ollama
# LLM_MODEL=llama2
# LLM_ENDPOINT=http://localhost:11434

# Scraper Settings
SCRAPY_LOG_LEVEL=INFO
DOWNLOAD_DELAY=2
MAX_PAGES=1000
CRAWL_DEPTH=3
